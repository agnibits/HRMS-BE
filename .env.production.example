# ═════════════════════════════════════════════════════════════════════════
# PRODUCTION environment (Lightsail single instance).
# Copy to `.env` on the server:  cp .env.production.example .env
# Then edit the values marked CHANGE_ME. NEVER commit the real .env.
# ═════════════════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=4000
API_PREFIX=/api/v1
APP_NAME=HRMS

# Public URL of this server. Use your Lightsail static IP (http, no domain yet).
APP_URL=http://CHANGE_ME_STATIC_IP
FRONTEND_URL=http://CHANGE_ME_STATIC_IP
LOG_LEVEL=info

# ─── Postgres (used by docker-compose to create the DB) ───────────────────
POSTGRES_USER=hrms
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=hrms
# DATABASE_URL & REDIS_URL are injected by docker-compose.prod.yml — leave unset.

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_DRIVER=redis

# ─── JWT secrets — generate with:  openssl rand -base64 48 ────────────────
JWT_ACCESS_SECRET=CHANGE_ME_run_openssl_rand_base64_48
JWT_REFRESH_SECRET=CHANGE_ME_run_openssl_rand_base64_48
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Security / rate limiting ─────────────────────────────────────────────
TRUST_PROXY=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# ─── CORS: your frontend origin(s), comma-separated ───────────────────────
CORS_ORIGINS=http://CHANGE_ME_STATIC_IP

# ─── Email (real SMTP — e.g. AWS SES, SendGrid, Gmail app password) ───────
MAIL_HOST=CHANGE_ME_smtp_host
MAIL_PORT=587
MAIL_USER=CHANGE_ME
MAIL_PASS=CHANGE_ME
MAIL_SECURE=false
MAIL_FROM="HRMS <no-reply@yourdomain.com>"

# ─── Storage (local disk by default; switch to s3 for AWS S3) ─────────────
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE_MB=15

# ─── Seed admin (change before first deploy) ──────────────────────────────
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ─── AI (Groq — free key: https://console.groq.com/keys) ─────────────────
GROQ_API_KEY=CHANGE_ME_groq_free_key
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Swagger: keep true to test the API, set false to hide docs in prod ───
ENABLE_SWAGGER=true
ENABLE_MFA=true
