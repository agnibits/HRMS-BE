# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
APP_NAME=HRMS
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://hrms:hrms@localhost:5432/hrms?schema=public

# ─────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# JWT / Auth
# ─────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
PASSWORD_RESET_EXPIRES_MIN=30
EMAIL_VERIFY_EXPIRES_HOURS=24
OTP_EXPIRES_MIN=5
BCRYPT_ROUNDS=12

# ─────────────────────────────────────────────────────────────
# Rate limiting
# ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# ─────────────────────────────────────────────────────────────
# CORS (comma-separated origins, or * for all)
# ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Mail (Nodemailer / SMTP)
# ─────────────────────────────────────────────────────────────
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_SECURE=false
MAIL_FROM="HRMS <no-reply@hrms.local>"

# ─────────────────────────────────────────────────────────────
# Object storage (AWS S3 / MinIO)
# ─────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=hrms
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
LOCAL_UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE_MB=15

# ─────────────────────────────────────────────────────────────
# Feature flags
# ─────────────────────────────────────────────────────────────
ENABLE_SWAGGER=true
ENABLE_MFA=true
TRUST_PROXY=false
