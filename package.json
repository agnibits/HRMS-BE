{
  "name": "hrms-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise HRMS backend — clean architecture, Node.js + Express + Prisma + PostgreSQL + Redis",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch --env-file=.env src/server.js",
    "dev:standalone": "node --env-file-if-exists=.env scripts/dev-standalone.mjs",
    "start": "node src/server.js",
    "worker": "node --env-file=.env src/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset --force",
    "lint": "eslint \"src/**/*.js\"",
    "format": "prettier --write \"src/**/*.js\"",
    "docker:up": "docker compose up -d postgres redis",
    "docker:down": "docker compose down"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.717.0",
    "@aws-sdk/s3-request-presigner": "^3.717.0",
    "@prisma/client": "^6.1.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "groq-sdk": "^1.3.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "nanoid": "^5.0.9",
    "nodemailer": "^6.9.16",
    "otplib": "^12.0.1",
    "pdfkit": "^0.15.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prisma": "^6.1.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.2.0",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "embedded-postgres": "^18.4.0-beta.17",
    "eslint": "^9.17.0",
    "ioredis-mock": "^8.13.1",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2"
  }
}
